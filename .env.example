# ── Supabase (catalog + prices + admin auth + image storage) ──────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser. Used by the price webhook + sync.
SUPABASE_SERVICE_ROLE_KEY=

# ── WooCommerce ───────────────────────────────────────────────────
# Shared secret configured on the WooCommerce product webhook.
WOO_WEBHOOK_SECRET=

# Storefront base (no trailing slash). Defaults to https://uniqook.co.il
NEXT_PUBLIC_STORE_BASE=https://uniqook.co.il
NEXT_PUBLIC_CART_PATH=/cart/

# Companion "add many to cart" target (see wordpress-snippet.php). The app
# appends ?oxo_cart=ID:QTY,... and the snippet adds them all + redirects to cart.
# If empty, the app falls back to sequential add-to-cart requests.
NEXT_PUBLIC_ADD_TO_CART_ENDPOINT=https://uniqook.co.il/

# Google Tag Manager container id (optional).
NEXT_PUBLIC_GTM_ID=GTM-TV96297
